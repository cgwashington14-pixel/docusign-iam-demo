# DocuSign account (demo or production)
DOCUSIGN_ACCOUNT_ID=your_account_id_here
DOCUSIGN_BASE_URI=https://demo.docusign.net
DOCUSIGN_USER_ID=your_user_guid_here

# DocuSign app credentials (Apps and Keys in developer console)
DOCUSIGN_INTEGRATION_KEY=your_integration_key_here
DOCUSIGN_CLIENT_SECRET=your_client_secret_here
DOCUSIGN_REDIRECT_URI=http://localhost:5051/oauth/callback

# Optional: static access token (JWT grant is preferred)
DOCUSIGN_ACCESS_TOKEN=

# JWT grant — use ONE of these:
# Local dev: save key to private.key (gitignored) or set path:
# RSA_PRIVATE_KEY_PATH=./private.key
# Vercel/production: paste PEM with literal \n line breaks:
# RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Flask session signing (generate: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change-me-in-production

# Optional: HMAC verification for Connect webhooks
WEBHOOK_SECRET=

# Optional: AI agent feature
ANTHROPIC_API_KEY=
